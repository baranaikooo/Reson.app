# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google OAuth Client ID (Web application) from Google Cloud Console.
# Authorized JavaScript origins must include your app URL (e.g. https://your-app.lovable.app).
# Note: If using Supabase Auth, this may not be needed as Supabase handles Google OAuth
VITE_GOOGLE_CLIENT_ID=
VITE_WEBHOOK_SECRET=
